linewidth = 1.5, color = "#2c3e50") +
# 2. El promedio de la simulación
geom_point(size = 5, color = "#2c3e50") +
# 3. La línea de referencia REAL (60%)
geom_hline(yintercept = 60, linetype = "dashed", color = "#e74c3c", linewidth = 1.2) +
# 4. Anotación de texto para enfatizar el error
annotate("text", x = 1, y = 62, label = "Observed Real Value (60%)",
